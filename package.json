{
  "name": "mande-design-system",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "description": "Mande Design System — components, tokens, and prototype playground",
  "scripts": {
    "dev": "turbo run dev",
    "dev:playground": "turbo run dev --filter=@mande/playground",
    "dev:storybook": "STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -p 6006",
    "build": "turbo run build",
    "build-storybook": "STORYBOOK_DISABLE_TELEMETRY=1 storybook build",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-interactions": "^8.6.18",
    "@storybook/addon-links": "^8.6.18",
    "@storybook/addon-onboarding": "^8.6.18",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "^4.7.0",
    "prettier": "^3.2.0",
    "storybook": "^8.6.18",
    "tailwindcss": "^4.2.2",
    "turbo": "^2",
    "typescript": "^5",
    "vite": "^6.4.1"
  }
}
